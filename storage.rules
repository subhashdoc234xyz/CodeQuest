rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Shared exports — readable by anyone with the link, writable only by auth users
    match /shares/{userId}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Articles — same pattern
    match /articles/{userId}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Roadmaps — same pattern
    match /roadmaps/{userId}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
