# Supabase Config
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Gemini API Key Pools (comma-separated or list of separate numbered variables)
# CodeQuest supports loading multiple keys either from comma-separated strings or numbered keys:

# Roadmap / DuckDuckGo synthesis block
GEMINI_ROADMAP_KEY_1=
GEMINI_ROADMAP_KEY_2=
GEMINI_ROADMAP_KEY_3=

# Light AI Assistant (chat / doubt clarification) block
GEMINI_CHAT_KEY_1=
GEMINI_CHAT_KEY_2=
GEMINI_CHAT_KEY_3=

# Visualizer / Explain / flowchart block
GEMINI_VISUALIZE_KEY_1=
GEMINI_VISUALIZE_KEY_2=
GEMINI_VISUALIZE_KEY_3=

PORT=5000
